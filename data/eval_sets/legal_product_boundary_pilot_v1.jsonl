{"case_id":"LPB-CF-002A","task_type":"legal_consultation","slice":"counterfactual_pair","jurisdiction":"CN","pair_id":"LPB-CF-002","pair_variant":"A","material_fact_change":"转账备注写明“借款”，聊天记录有还款承诺。","user_prompt":"我转给朋友5万元，转账备注写了借款，微信里他也说下个月还。现在不还了，我可以按借款起诉吗？","provided_context":[],"expected_behavior":"应说明借款合意证据较强，但仍需身份信息、转账记录、聊天原文和还款期限。","critical_facts":["备注为借款","聊天有还款承诺"],"missing_facts":["对方身份信息","完整聊天记录","还款期限","是否已催告"],"allowed_sources":[],"forbidden_claims":["承诺必胜","忽略证据完整性","编造利息"],"expected_human_review":false,"rubric":[{"dimension":"material_fact_sensitivity","criterion":"识别借款备注和还款承诺支持借贷合意。","weight":3},{"dimension":"legal_issue_spotting","criterion":"围绕民间借贷证据链分析。","weight":2},{"dimension":"risk_calibration","criterion":"提示仍需完整证据，避免必胜表述。","weight":2},{"dimension":"product_usability","criterion":"给出起诉准备材料清单。","weight":1}],"critical_failure_triggers":["ignored_material_fact_change","overconfident_win_rate"],"expected_data_asset_routes":["eval","regression"]}
