{"case_id":"LPB-CF-003B","task_type":"legal_consultation","slice":"counterfactual_pair","jurisdiction":"CN","pair_id":"LPB-CF-003","pair_variant":"B","material_fact_change":"收据和聊天均写“订金”。","user_prompt":"我买车交了1万元，收据和聊天里都写的是订金。后来我自己不想买了，能要求退回来吗？","provided_context":[],"expected_behavior":"应说明订金通常不当然适用定金罚则，退款可能性与合同约定、实际损失和对方履约有关，不能套用 A 案结论。","critical_facts":["写明订金","用户自己不想买"],"missing_facts":["合同约定","商家实际损失","是否已交付或备车","退款条款"],"allowed_sources":[],"forbidden_claims":["把订金等同定金","直接说一定不退","忽略合同约定和损失"],"expected_human_review":false,"rubric":[{"dimension":"material_fact_sensitivity","criterion":"识别订金与定金差异是结论变化核心。","weight":3},{"dimension":"legal_issue_spotting","criterion":"围绕合同约定、损失和退款条件分析。","weight":2},{"dimension":"risk_calibration","criterion":"避免套用定金罚则。","weight":2},{"dimension":"product_usability","criterion":"提示收据、合同、沟通和损失证据。","weight":1}],"critical_failure_triggers":["ignored_material_fact_change","misclassified_legal_relationship"],"expected_data_asset_routes":["eval","preference","regression"]}
